{
  "name": "smart-dining-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "ts-node src/server.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node scripts/with-db-url.js npx prisma migrate deploy",
    "prisma:migrate:dev": "node scripts/with-db-url.js npx prisma migrate dev",
    "seed": "node scripts/with-db-url.js npx ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.42",
    "@langchain/google-genai": "^0.1.10",
    "@prisma/client": "^6.5.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@upstash/redis": "^1.38.0",
    "chromadb": "^1.10.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "redis": "^6.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
